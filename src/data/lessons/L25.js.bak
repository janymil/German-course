  exercises: [
    {
      type: "flashcard",
      instruction: "Prezri si datívne predložky a ich sťahovania. Venuj zvláštnu pozornosť sťahovaniam (beim, vom, zum, zur).",
      items: [
        "mit + Dativ = s, so (spolu s niečím)",
        "bei + Dativ = u, pri (blízkosť / zamestnávateľ)",
        "nach + Dativ = do (smer) / po (čas)",
        "von + Dativ = od, z",
        "zu + Dativ = k, ku, do",
        "aus + Dativ = z, zo (pôvod)",
        "seit + Dativ = od (trvá dodnes)",
        "gegenüber + Dativ = oproti",
        "beim = bei + dem (M/N)",
        "vom = von + dem (M/N)",
        "zum = zu + dem (M/N)",
        "zur = zu + der (F)",
        "der Arzt / die Ärztin = lekár / lekárka",
        "das Büro = kancelária",
        "seit wann? = od kedy?"
      ]
